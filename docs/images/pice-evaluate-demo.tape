# VHS tape file for recording the README Stack Loops demo GIF.
# Regenerate with: vhs docs/images/pice-evaluate-demo.tape
# Must be run from the repository root directory.

Output docs/images/pice-evaluate-demo.gif

Set Shell "bash"
Set FontSize 18
Set Width 960
Set Height 540
Set Theme "Builtin Dark"
Set Padding 24
Set Framerate 15

Hide
Type "bash docs/images/pice-evaluate-demo.sh"
Enter
Sleep 500ms
Show

Sleep 9s
